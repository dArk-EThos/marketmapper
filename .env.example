# Market Mapper — Environment Variables
# Copy this to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (production uses PostgreSQL)
DATABASE_URL=postgresql://marketmapper_user:password@localhost/marketmapper

# For development, Django defaults to SQLite if DATABASE_URL is not set
